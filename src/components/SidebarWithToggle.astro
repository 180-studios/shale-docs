---
import Default from '@astrojs/starlight/components/Sidebar.astro';
---

<div id="sidebar-toggle-btn" title="Toggle sidebar">&#8249;</div>
<Default {...Astro.props}><slot /></Default>

<script>
  function init() {
    const btn = document.getElementById('sidebar-toggle-btn');
    const sidebar = document.querySelector('.sidebar-pane') as HTMLElement;
    const mainFrame = document.querySelector('.main-frame') as HTMLElement;
    if (!btn || !sidebar || !mainFrame) return;

    let collapsed = sessionStorage.getItem('sidebarCollapsed') === 'true';

    function apply() {
      if (collapsed) {
        sidebar.style.width = '0px';
        sidebar.style.overflow = 'hidden';
        mainFrame.style.paddingInlineStart = '0px';
        btn!.style.left = '0.5rem';
        btn!.textContent = '›';
      } else {
        sidebar.style.width = '';
        sidebar.style.overflow = '';
        mainFrame.style.paddingInlineStart = '';
        btn!.style.left = '';
        btn!.textContent = '‹';
      }
    }

    btn.addEventListener('click', () => {
      collapsed = !collapsed;
      sessionStorage.setItem('sidebarCollapsed', String(collapsed));
      apply();
    });

    apply();
  }

  document.addEventListener('DOMContentLoaded', init);
</script>

<style is:global>
  #sidebar-toggle-btn {
    position: fixed;
    top: calc(var(--sl-nav-height) + 1rem);
    left: var(--sl-sidebar-width);
    z-index: 9999;
    width: 1.5rem;
    height: 1.5rem;
    display: none;
    align-items: center;
    justify-content: center;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 4px;
    cursor: pointer;
    font-size: 1.4rem;
    line-height: 1;
    color: var(--sl-color-text);
    user-select: none;
  }

  @media (min-width: 50rem) {
    #sidebar-toggle-btn {
      display: flex;
    }
  }
</style>
